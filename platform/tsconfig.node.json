{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "composite": true,
    "emitDeclarationOnly": true,
    "outDir": "./node_modules/.cache/types-node",
    "types": ["node"]
  },
  "include": ["vite.config.ts", "vitest.config.ts", "tailwind.config.ts"]
}
